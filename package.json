{
  "name": "onc-backend",
  "version": "1.0.0",
  "description": "Ultra Secure Backend for ONC Jansewa Kendra",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test:intents": "node test_suite/runNeuralTests.js 03",
    "test:conversation": "node test_suite/runNeuralTests.js 04",
    "test:responses": "node test_suite/runNeuralTests.js 10",
    "test:safety": "node test_suite/runNeuralTests.js 01",
    "test:data": "node test_suite/runNeuralTests.js 05",
    "test:performance": "node test_suite/runPerformanceTests.js",
    "test:all": "npm run test:intents && npm run test:conversation && npm run test:responses && npm run test:safety && npm run test:data && npm run test:performance",
    "test:live-ai": "node test_suite/runLiveAiTests.js",
    "test:brain": "node test_suite/runNeuralTests.js",
    "test:release": "npm run test:all && npm run test:brain",
    "test:release-live": "npm run test:all && npm run test:brain && npm run test:live-ai"
  },
  "dependencies": {
    "axios": "^1.18.1",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.0.0-rc.12",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.1.5",
    "google-tts-api": "^2.0.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.5.0",
    "morgan": "^1.10.0",
    "nodemon": "^3.0.1",
    "validator": "^13.11.0",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "dotenv": "^16.3.1"
  }
}
