# Copy this file to .env and fill in real values. Never commit the real .env.
# Vars marked REQUIRED will stop the server from starting if missing
# (see src/config/validateEnv.js). Everything else has a safe default.

# ── Core (REQUIRED) ─────────────────────────────────────────────
MONGO_URI=mongodb://127.0.0.1:27017/onc_db
JWT_SECRET=
# ─────────────────────────────────────────────────────────────────

PORT=3001
HOST=0.0.0.0
NODE_ENV=development
JWT_EXPIRES_IN=90d

# Comma-separated list of browser origins allowed to call this API in
# production (e.g. https://admin.yourdomain.com). Required in production if
# any browser (not just the mobile app) needs to reach these endpoints -
# without it, all browser cross-origin requests are blocked by default.
CORS_ORIGINS=

# Redis - powers the shared rate limiter, AI response cache, auth cache,
# BullMQ background job queue, and Socket.io multi-instance broadcast.
# Falls back to per-instance in-memory behavior if unreachable, but you lose
# the "shared across instances" guarantees that matter at scale.
REDIS_URL=redis://127.0.0.1:6379

# LLM provider
GROQ_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
LLM_PROVIDER=
LLM_BASE_URL=
LLM_MODEL=
AI_LOGIC_MODEL=
AI_PERSONALITY_MODEL=
AI_VISION_MODEL=
AI_REASONING_MODEL=
AI_GUARD_MODEL=
AI_VERIFY_MODEL=
LLM_MAX_TOKENS=1500
LLM_TINY_MAX_TOKENS=
LLM_STANDARD_MAX_TOKENS=
LLM_DEEP_MAX_TOKENS=
LLM_SETTINGS_TTL_MS=60000
AI_RATE_LIMIT_PER_HOUR=40
# Caps how many LLM HTTP calls this process has in flight at once.
LLM_MAX_CONCURRENT=20
# After this many consecutive LLM failures, stop calling the provider for
# LLM_CIRCUIT_COOLDOWN_MS instead of retrying into an outage.
LLM_CIRCUIT_FAILURE_THRESHOLD=8
LLM_CIRCUIT_COOLDOWN_MS=15000

# Embeddings (job search)
EMBEDDING_PROVIDER=
EMBEDDING_MODEL=
EMBEDDING_TIMEOUT_MS=8000
EMBEDDING_VECTOR_SIZE=384
EMBEDDING_CACHE_TTL_MS=600000
EMBEDDING_CACHE_MAX=500

# Third-party integrations
SEARCH_API_KEY=
SERP_API_KEY=
OCR_API_KEY=
MSG91_WIDGET_ID=
MSG91_WIDGET_AUTH_TOKEN=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_PREMIUM_OFFERS_JSON=

# Error tracking (optional - errors still log to console without this)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Mongo connection pool - shared across all traffic from this process
# (API requests, admin dashboard, socket.io, background jobs).
MONGO_MAX_POOL_SIZE=100
MONGO_MIN_POOL_SIZE=5

# Misc tuning
MY_MATCHES_MAX_JOBS_SCANNED=500
BACKGROUND_WORKER_CONCURRENCY=5
SOURCE_FETCH_TIMEOUT_MS=
DEBUG=false
DEBUG_RETRIEVAL=false
